#!/usr/bin/env python3
"""Re-apply local vibesignal customizations after `uv tool upgrade/install vibesignal`.

Upstream ships no appearance config, so the dark theme lives as source patches on
the installed widget.py; the tool venv also needs Tcl/Tk symlinked in (uv-managed
CPython keeps them outside the venv). Both are wiped whenever uv rebuilds the
venv — rerun this script afterwards. It is idempotent.
"""
import glob
import os
import subprocess
import sys

TOOL = os.path.expanduser("~/.local/share/uv/tools/vibesignal")

# (light-theme original, dark-theme replacement) — keep in sync with upstream widget.py
REPLACEMENTS = [
