def link_tcl():
    """Symlink the interpreter's Tcl/Tk library dirs into the tool venv."""
    home = None
    with open(os.path.join(TOOL, "pyvenv.cfg")) as f:
        for line in f:
            if line.split("=")[0].strip() == "home":
                home = line.split("=", 1)[1].strip()
    if not home:
        sys.exit("pyvenv.cfg has no 'home' key; cannot locate the base interpreter")
    pylib = os.path.join(os.path.dirname(home), "lib")
    for name in ("tcl9.0", "tk9.0", "tcl8.6", "tk8.6"):
        src = os.path.join(pylib, name)
        dst = os.path.join(TOOL, "lib", name)
        if os.path.isdir(src) and not os.path.exists(dst):
            os.symlink(src, dst)
            print(f"linked {dst} -> {src}")


def patch_widget():
    paths = glob.glob(os.path.join(TOOL, "lib/python*/site-packages/vibesignal/widget.py"))
    if not paths:
        sys.exit("widget.py not found; is vibesignal installed via uv tool?")
    path = paths[0]
    with open(path) as f:
        src = f.read()
    changed = False
    for old, new in REPLACEMENTS:
        if new in src:
            continue
        if old not in src:
            print(f"WARNING: upstream widget.py changed; pattern not found:\n  {old.splitlines()[0]}…")
            continue
        src = src.replace(old, new)
        changed = True
    if changed:
        with open(path, "w") as f:
            f.write(src)
        print(f"patched {path}")
    else:
        print("widget.py already patched")


def restart_widget():
    subprocess.run(
        ["launchctl", "kickstart", "-k", f"gui/{os.getuid()}/io.github.yzhao062.vibesignal"],
        check=False,
    )
    print("widget restarted")


if __name__ == "__main__":
    link_tcl()
    patch_widget()
    restart_widget()
